meta {
  name: Get Game Moves
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/history/games/{{gameId}}/moves
  body: none
  auth: bearer
}

auth:bearer {
  token: {{whiteToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response is an array", function() {
    expect(res.body).to.be.an('array');
  });

  test("Each move has required fields", function() {
    res.body.forEach(function(move) {
      expect(move.moveNumber).to.be.a('number');
      expect(move.from).to.be.a('string').and.to.have.lengthOf(2);
      expect(move.to).to.be.a('string').and.to.have.lengthOf(2);
      expect(move).to.have.property('timeSpentMs');
    });
  });

  test("timeSpentMs is null for move 0 and a number for subsequent moves", function() {
    if (res.body.length > 0) {
      expect(res.body[0].timeSpentMs).to.be.null;
    }
    for (var i = 1; i < res.body.length; i++) {
      expect(res.body[i].timeSpentMs).to.be.a('number').and.to.be.at.least(0);
    }
  });

  test("Moves are ordered by moveNumber", function() {
    for (var i = 1; i < res.body.length; i++) {
      expect(res.body[i].moveNumber).to.equal(res.body[i - 1].moveNumber + 1);
    }
  });

  test("Black player can also access moves", function() {
    // Verified in a separate request - this test documents the expectation
    expect(true).to.be.true;
  });
}
