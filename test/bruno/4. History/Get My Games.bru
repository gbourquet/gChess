meta {
  name: Get My Games
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/history/games
  body: none
  auth: bearer
}

auth:bearer {
  token: {{whiteToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response is an array", function() {
    expect(res.body).to.be.an('array');
  });

  test("At least one game found — sets gameId for subsequent requests", function() {
    expect(res.body.length).to.be.greaterThan(0);
    bru.setEnvVar("gameId", res.body[0].gameId);
  });

  test("Game summary has required fields", function() {
    const game = res.body[0];
    expect(game.gameId).to.be.a('string');
    expect(game.whiteUserId).to.be.a('string');
    expect(game.blackUserId).to.be.a('string');
    expect(game.status).to.be.a('string');
    expect(game.moveCount).to.be.a('number');
  });

  test("White player is in the game", function() {
    const game = res.body[0];
    const whitePlayerId = bru.getEnvVar("whitePlayerId");
    const isParticipant = game.whiteUserId === whitePlayerId || game.blackUserId === whitePlayerId;
    expect(isParticipant).to.be.true;
  });
}
